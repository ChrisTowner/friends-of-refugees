---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('press')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = new Intl.DateTimeFormat('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="Press & Media — Teri Towner" description="Media coverage, press mentions, and interviews featuring Teri Towner.">
  <section class="page-header">
    <div class="container-narrow">
      <span class="eyebrow">Press &amp; Media</span>
      <h1>In the news</h1>
      <p class="lead">Coverage, interviews, and mentions from local media.</p>
    </div>
  </section>

  <section>
    <div class="container-narrow">
      {items.length === 0 ? (
        <p class="muted">No coverage listed yet.</p>
      ) : (
        <ul class="press-list">
          {items.map((item) => (
            <li class="press-item card">
              <div class="meta">
                <strong>{item.data.publication}</strong>
                <time datetime={item.data.date.toISOString()}>{fmt.format(item.data.date)}</time>
              </div>
              <h3>
                {item.data.link ? (
                  <a href={item.data.link} rel="noopener" target="_blank">{item.data.title}</a>
                ) : item.data.title}
              </h3>
              {item.data.excerpt && <p>{item.data.excerpt}</p>}
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <section class="media-contact">
    <div class="container-narrow center">
      <h2>Media inquiries</h2>
      <p>For interviews or press questions, please reach out through the contact form.</p>
      <a href="/contact/" class="btn btn-outline">Contact the campaign</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-xl) 0 var(--space-md);
    background: color-mix(in srgb, var(--color-primary) 8%, var(--color-cream));
  }
  .press-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .press-item { padding: var(--space-md); }
  .press-item .meta { display: flex; justify-content: space-between; color: var(--color-muted); font-size: 0.9rem; margin-bottom: 0.25rem; }
  .press-item h3 { margin: 0.25rem 0 0.5rem; }
  .press-item p { color: var(--color-muted); margin: 0; }
  .media-contact { padding: var(--space-xl) 0; background: color-mix(in srgb, var(--color-accent) 12%, var(--color-cream)); }
  .center { text-align: center; }
  .muted { color: var(--color-muted); }
</style>
