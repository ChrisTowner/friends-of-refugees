---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---
<BaseLayout title={`About ${site.candidateName} — Coquitlam City Council`} description="Learn about Teri Towner's background, community involvement, and work on Coquitlam City Council.">
  <section class="page-header">
    <div class="container-narrow">
      <span class="eyebrow">Meet Teri</span>
      <h1>About Teri Towner</h1>
      <p class="lead">PLACEHOLDER — A friendly one-line intro that summarizes Teri in a sentence.</p>
    </div>
  </section>

  <section class="about-main">
    <div class="container">
      <div class="about-grid">
        <div class="about-photo">
          <!--
            REPLACE with a warm photo — Teri at a community event, with family, or in nature.
            Recommended: 900×1100px, JPG, < 250KB. Path: /public/images/teri-about.jpg
          -->
          <img
            src="/images/teri-badseed.jpg"
            alt={`${site.candidateName} portrait`}
            width="500"
            height="600"
            loading="lazy"
          />
          <p class="caption">PLACEHOLDER — Photo caption (e.g., "Teri at the Coquitlam Terry Fox Run, 2024").</p>
        </div>
        <article class="prose">
          <h2>Hello, I'm Teri.</h2>
          <p>
            I've lived in Coquitlam for 20 years and I'm raising my two teens, Jessica and Christopher,
            in this beautiful city. I was first elected to Coquitlam City Council in 2014, and I'm running
            again in 2026 because there's more work to do for the city we all love.
          </p>

          <h3>Background</h3>
          <ul>
            <li>Business degree from Simon Fraser University</li>
            <li>10 years in retail banking</li>
            <li>16 years with a major BC utility in Human Resources management and analyst roles</li>
            <li>One year as a Special Events Officer for a local non-profit</li>
          </ul>

          <h3>On Council (since 2014)</h3>
          <ul>
            <li>Chair — Sustainability and Environmental Advisory Committee</li>
            <li>Vice Chair — Parcel Tax Review Panel</li>
            <li>Member — Metro Vancouver Housing Committee</li>
            <li>Council Representative — Tri-Cities Homelessness and Housing Task Group</li>
            <li>Alternate — Coquitlam River Watershed Roundtable</li>
          </ul>

          <h3>Community involvement</h3>
          <ul>
            <li>Board of Directors — Community Volunteer Connections</li>
            <li>Habitat for Humanity Family Partnering Committee</li>
            <li>Co-founder and current Chair — TriCities Friends of Refugees Task Group (TFOR)</li>
            <li>TFOR representative — BC TriCities Chapter of Organizing Against Racism &amp; Hate</li>
            <li>Active member — Talk of the Town Toastmasters Club</li>
            <li>Longtime volunteer with SHARE, Raise-a-Reader, Operation Red Nose, Terry Fox Run,
              Pink Shirt Day, Shoreline Cleanup, Adopt-a-Street, and the 55+ BC Summer Games</li>
            <li>PAC executive — 8 years elementary, 5 years middle, 2+ years secondary, and DPAC43 since 2010</li>
          </ul>

          <h3>Honours</h3>
          <ul>
            <li>2013 BCCPAC Award for Excellence in Parent Leadership</li>
            <li>2017 Women's Collaborative Hub "Inspirational Wonder Woman" award (inaugural recipient)</li>
            <li>Nominated — Society for Community Development "Spirit of Community" award</li>
            <li>Nominated — SportMedBC SunRun clinic "Leader of the Year"</li>
          </ul>

          <blockquote>
            PLACEHOLDER QUOTE — A short personal line from Teri about what she cares about most.
          </blockquote>

          <p class="note">
            <em>Note: this bio is a placeholder based on earlier content and needs to be updated with
            Teri's current priorities, committees, and recent work.</em>
          </p>

          <p>
            <a href="/get-involved/" class="btn btn-primary">Join the campaign</a>
            &nbsp;
            <a href="/platform/" class="btn btn-outline">See the platform</a>
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-xl) 0 var(--space-md);
    background: color-mix(in srgb, var(--color-accent) 14%, var(--color-cream));
  }
  .page-header h1 { margin: 0.25rem 0; }
  .page-header .lead { color: var(--color-muted); font-size: 1.15rem; }

  .about-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.3fr;
    gap: var(--space-lg);
    align-items: start;
  }
  .about-photo img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    width: 100%;
    height: auto;
    background: var(--color-accent);
  }
  .about-photo .caption {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
    text-align: center;
  }
  .note { font-size: 0.9rem; color: var(--color-muted); }
  @media (max-width: 880px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-photo { max-width: 340px; margin: 0 auto; }
  }
</style>
