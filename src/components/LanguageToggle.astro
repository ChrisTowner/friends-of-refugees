---
// Thin wrapper around the Google Translate widget (initialized in BaseLayout).
// We render our own select that proxies to the hidden Google one — gives us styling control.
---
<div class="lang-wrap">
  <label for="lang-select" class="sr-only">Choose language</label>
  <select id="lang-select" aria-label="Choose language">
    <option value="">🌐 English</option>
    <option value="zh-CN">中文 (简体)</option>
    <option value="zh-TW">中文 (繁體)</option>
    <option value="ko">한국어</option>
    <option value="fa">فارسی</option>
    <option value="pa">ਪੰਜਾਬੀ</option>
    <option value="es">Español</option>
    <option value="fr">Français</option>
    <option value="tl">Filipino</option>
    <option value="vi">Tiếng Việt</option>
  </select>
</div>

<style>
  .lang-wrap select {
    font-size: 0.88rem;
    padding: 0.45rem 0.6rem;
    min-height: 40px;
    width: auto;
    border-radius: 999px;
    border: 1.5px solid var(--color-border);
    background: var(--color-white);
    color: var(--color-text);
    cursor: pointer;
  }
  .lang-wrap select:hover { border-color: var(--color-primary); }
</style>

<script is:inline>
  (function () {
    const sel = document.getElementById('lang-select');
    if (!sel) return;

    function setCookie(name, value) {
      const host = location.hostname;
      const parts = host.split('.');
      const rootDomain = parts.length > 1 ? '.' + parts.slice(-2).join('.') : host;
      document.cookie = `${name}=${value}; path=/; domain=${rootDomain}`;
      document.cookie = `${name}=${value}; path=/`;
    }

    sel.addEventListener('change', () => {
      const v = sel.value;
      if (!v) {
        setCookie('googtrans', '/en/en');
      } else {
        setCookie('googtrans', `/en/${v}`);
      }
      location.reload();
    });

    // Restore selection on load
    const match = document.cookie.match(/googtrans=\/en\/([^;]+)/);
    if (match && match[1] !== 'en') sel.value = match[1];
  })();
</script>
