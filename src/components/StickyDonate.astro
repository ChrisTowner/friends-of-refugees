---
import site from '../data/site.json';
const href = site.donationLink && site.donationLink !== '#' ? site.donationLink : '/get-involved/#donate';
---
<a href={href} class="sticky-donate" aria-label="Donate to the campaign">
  <span aria-hidden="true">♥</span>
  <span class="label">Donate</span>
</a>

<style>
  .sticky-donate {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 40;
    background: var(--color-primary);
    color: var(--color-white);
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    font-size: 1rem;
    display: none;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 10px 28px rgba(31, 41, 55, 0.25);
    transition: transform 180ms var(--ease), background 180ms var(--ease);
    min-height: 48px;
  }
  .sticky-donate:hover {
    background: var(--color-primary-dark);
    color: var(--color-white);
    transform: translateY(-2px);
  }
  .sticky-donate span[aria-hidden] {
    font-size: 1.1rem;
    line-height: 1;
  }
  @media (max-width: 880px) {
    .sticky-donate { display: inline-flex; }
  }
</style>
