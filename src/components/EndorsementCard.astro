---
interface Props {
  name: string;
  role?: string;
  quote: string;
  image?: string;
}
const { name, role, quote, image } = Astro.props;
---
<figure class="endorsement card">
  <blockquote>“{quote}”</blockquote>
  <figcaption>
    {image && <img src={image} alt={`Photo of ${name}`} width="48" height="48" loading="lazy" />}
    <div>
      <strong>{name}</strong>
      {role && <span>{role}</span>}
    </div>
  </figcaption>
</figure>

<style>
  .endorsement {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }
  .endorsement blockquote {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    line-height: 1.55;
    margin: 0;
    color: var(--color-text);
    border: none;
    padding: 0;
    font-style: normal;
  }
  .endorsement figcaption {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    padding-top: 0.85rem;
  }
  .endorsement figcaption img {
    border-radius: 999px;
    object-fit: cover;
    width: 48px; height: 48px;
  }
  .endorsement figcaption strong { display: block; font-family: var(--font-body); }
  .endorsement figcaption span { font-size: 0.9rem; color: var(--color-muted); }
</style>
