---
interface Props {
  title: string;
  date: Date;
  excerpt?: string;
  image?: string;
  href: string;
}
const { title, date, excerpt, image, href } = Astro.props;
const dateLabel = new Intl.DateTimeFormat('en-CA', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---
<a class="post-card card" href={href}>
  {image && (
    <img src={image} alt="" width="600" height="360" loading="lazy" />
  )}
  <div class="post-body">
    <time datetime={date.toISOString()}>{dateLabel}</time>
    <h3>{title}</h3>
    {excerpt && <p>{excerpt}</p>}
    <span class="read-more">Read post →</span>
  </div>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    padding: 0;
  }
  .post-card img {
    aspect-ratio: 5 / 3;
    object-fit: cover;
    width: 100%;
  }
  .post-body { padding: var(--space-md); display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .post-body time { font-size: 0.85rem; color: var(--color-muted); }
  .post-body h3 { margin: 0; }
  .post-body p { color: var(--color-muted); margin: 0; }
  .read-more { margin-top: auto; color: var(--color-primary-dark); font-weight: 600; padding-top: 0.5rem; }
</style>
